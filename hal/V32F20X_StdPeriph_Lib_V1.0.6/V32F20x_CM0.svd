              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FASTEN</name>
              <description>Enables fast locking circuit</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>WDTRSTC</name>
