              <bitOffset>19</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>CLKF</name>
              <description>A 13 bit bus that selects the values
              1 to 8192 for the multiplication
              factor NF </description>
              <bitOffset>6</bitOffset>
              <bitWidth>13</bitWidth>
            </field>
            <field>
              <name>CLKR</name>
              <description>A 6 bit bus that selects the values
              1 to 64 for the reference divider
              NR </description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PLL1C3</name>
          <displayName>PLL1C3</displayName>
          <description>PLL1 control register 3</description>
          <addressOffset>0x34</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000EA5</resetValue>
          <fields>
            <field>
              <name>BWADJ</name>
              <description>A 12 bit bus that selects the values
