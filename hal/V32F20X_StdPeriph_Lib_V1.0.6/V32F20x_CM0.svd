    <peripheral>
      <name>CRYPT</name>
      <description>CRYPT Peripheral Interface</description>
      <groupName>CRYPT</groupName>
      <baseAddress>0x4120C000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CTRL</name>
          <displayName>CTRL</displayName>
          <description>CRYPT control register.</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>NOSTOP</name>
              <description>This register is used to control
              if the CPU will be stop by CRYPT
              engine when the CRYPT engine is
              busy and CPU read or write CRYPT
              engine register</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LENGTH</name>
              <description>This bit is used to control the
              VLI length of current operation
             </description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>MODE</name>
              <description>This register controls the operation
              mode of crypt engine</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>ACT</name>
              <description>Write 1 to this bit will start
              an operation specified in the MODE
              register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PTRA</name>
          <displayName>PTRA</displayName>
          <description>CRYPT pointer A register.</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
