          <addressOffset>0x2000</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CMD_REJECT_INT_SET</name>
              <description>Enables CMD_REJECT_IRQ bit to generate interrupts.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_FAIL_INT_SET</name>
              <description>Enables CMD_FAIL_IRQ bit to generate interrupts.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_SUCCESS_INT_SET</name>
              <description>Enables CMD_SUCCESS_IRQ bit to
              generate interrupts</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_ACCEPT_INT_SET</name>
              <description>Enables CMD_ACCEPT_IRQ bit to generate interrupts.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_INT_CLR</name>
          <displayName>GFC_INT_CLR</displayName>
          <description>GFC interrupt enable clear register for disabling generation of interrupt</description>
          <addressOffset>0x2004</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CMD_REJECT_INT_CLR</name>
              <description>Disables CMD_REJECT_IRQ bit</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_FAIL_INT_CLR</name>
              <description>Disables CMD_FAIL_IRQ bit</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_SUCCESS_INT_CLR</name>
              <description>Disables CMD_SUCCESS_IRQ bit</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_ACCEPT_INT_CLR</name>
              <description>Disables CMD_ACCEPT_IRQ bit</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_STATUS_SET</name>
          <displayName>GFC_STATUS_SET</displayName>
          <description>GFC interrupt status set register for activating different interrupt sources</description>
          <addressOffset>0x2008</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000020</resetValue>
          <fields>
            <field>
              <name>CMD_REJECT_STS_SET</name>
              <description>Sets the status of the CMD_REJECT_IRQ bit.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_FAIL_STS_SET</name>
              <description>Sets the status of the CMD_FAIL_IRQ bit.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_SUCCESS_STS_SET</name>
              <description>Sets the status of the CMD_SUCCESS_IRQ bit.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_ACCEPT_STS_SET</name>
              <description>Sets the status of the CMD_ACCEPT_IRQ bit.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_STATUS_CLR</name>
          <displayName>GFC_STATUS_CLR</displayName>
          <description>GFC interrupt status clear register for acknowledging different interrupt sources</description>
          <addressOffset>0x200C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000020</resetValue>
          <fields>
            <field>
              <name>CMD_REJECT_STS_CLR</name>
              <description>Clears the status of the CMD_REJECT_IRQ bit.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CCMD_FAIL_STS_CLR</name>
              <description>Clears the status of the CMD_FAIL_IRQ bit.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_SUCCESS_STS_CLR</name>
              <description>Clears the status of the CMD_SUCCESS_IRQ bit.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_ACCEPT_STS_CLR</name>
              <description>Clears the status of the CMD_ACCEPT_IRQ bit.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_MASKED_STATUS</name>
          <displayName>GFC_MASKED_STATUS</displayName>
          <description>GFC interrupt status register that shows if each interrupt is pending and is the cause of the interrupt line being asserted</description>
          <addressOffset>0x2010</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CMD_REJECT_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_REJECT_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_FAIL_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_FAIL_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_SUCCESS_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_SUCCESS_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_ACCEPT_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_ACCEPT_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_CTRL</name>
          <displayName>GFC_CTRL</displayName>
          <description>GFC control register for initiating Flash accesses</description>
          <addressOffset>0x2014</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ABORT</name>
              <description>Abort currently ongoing command
              that is initiated towards the Flash
              from the APB interface</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD</name>
              <description>Initiate a command to the Flash
              for the address that is stored
              in the ADDR register and with the
              data that are stored in DATA0 register
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_STATUS</name>
          <displayName>GFC_STATUS</displayName>
          <description>GFC status register for showing the state of the Flash accesses</description>
          <addressOffset>0x2018</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ARBITRATION_LOCKED</name>
              <description>Arbitration locked</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_FINISH</name>
              <description>Command finish</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_FAIL</name>
              <description>Command fail</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_SUCCESS</name>
              <description>Command success</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_ACCEPT</name>
              <description>Command accept</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_PENDING</name>
              <description>Command pening</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_ADDR</name>
          <displayName>GFC_ADDR</displayName>
          <description>GFC address register for the Flash access.</description>
          <addressOffset>0x201C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ADDR</name>
              <description>The 22 bit wide byte address for
              the current Flash access</description>
              <bitOffset>0</bitOffset>
              <bitWidth>22</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_DATA0</name>
          <displayName>GFC_DATA0</displayName>
          <description>GFC data register for the Flash access containing read and write data bits[31:0]</description>
          <addressOffset>0x2020</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA0</name>
              <description>Data register for the Flash access
              has read and write data bits 31
              0 </description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_DATA1</name>
          <displayName>GFC_DATA1</displayName>
          <description>GFC data register for the Flash access containing read data bits[63:32]</description>
          <addressOffset>0x2024</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA1</name>
              <description>Data register for the Flash access
              has read data bits 63 32 </description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_DATA2</name>
          <displayName>GFC_DATA2</displayName>
          <description>GFC data register for the flash access containing read data bits[95:64]</description>
          <addressOffset>0x2028</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA2</name>
              <description>Data register for the Flash access
              has read data bits 95 64 </description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_DATA3</name>
          <displayName>GFC_DATA3</displayName>
          <description>GFC data register for the Flash access has read data bits[127:96]</description>
          <addressOffset>0x202C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA3</name>
              <description>Data register for the Flash access
              has read data bits 127 96 </description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
