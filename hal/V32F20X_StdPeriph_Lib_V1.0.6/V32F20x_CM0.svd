              NB </description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>PLL1C4</name>
          <displayName>PLL1C4</displayName>
          <description>PLL1 control register 4</description>
