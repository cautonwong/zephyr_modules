    <peripheral>
      <name>WAVER</name>
      <description>WAVER Peripheral Interface</description>
      <groupName>WAVER</groupName>
      <baseAddress>0x21014000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CFG</name>
          <displayName>CFG</displayName>
          <description>WAVER configuration register</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>WAVER module enable control.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENDIAN</name>
              <description>Endian configuration.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BAKEN</name>
              <description>The backup waveform for CM0 processing control.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LEN</name>
              <description>The number of samples per-cycle.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>TRANSEN</name>
              <description>Transport the upload Waveform to
              CM33 system enable control</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>UPLOADEN</name>
              <description>Waveform sample upload enable control.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CICEN</name>
              <description>CIC Down sample enable.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CICSEL</name>
              <description>Down sample rate selection.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>COMPEN</name>
              <description>Compensation enable control.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>MODE</name>
          <displayName>MODE</displayName>
          <description>WAVER mode configuration register</description>
          <addressOffset>0x30</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MODE</name>
              <description>Waver mode configuration.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <displayName>DATA</displayName>
          <description>WAVER data register</description>
          <addressOffset>0x40</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA</name>
              <description>Sample data buffer candidate for FFT analysis.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>INFO</name>
          <displayName>INFO</displayName>
          <description>WAVER information register</description>
          <addressOffset>0x4C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LOCKERR</name>
              <description>A Lock Error has been occur between
              two cycles wave</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LOCKERRCNT</name>
              <description>Flame count of Lock Error cycles.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>INTGRITYERR</name>
              <description>An integrity error occurred while receiving data.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INTGRITYERRCNT</name>
              <description>Flame count of Integrity Error cycles.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STATE</name>
          <displayName>STATE</displayName>
          <description>WAVER state register</description>
          <addressOffset>0x50</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FCNT</name>
              <description>Current flame count.</description>
              <bitOffset>21</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>OPCNT</name>
              <description>Current operation count (max 256).</description>
              <bitOffset>12</bitOffset>
              <bitWidth>9</bitWidth>
            </field>
            <field>
              <name>IBOUNDSTS</name>
              <description>Integrity Error occur on IB SPI0 interface.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>I2C14</name>
      <description>I2C14 Peripheral Interface</description>
      <groupName>I2C</groupName>
      <baseAddress>0x41010000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x800</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CON</name>
          <displayName>CON</displayName>
          <description>I2C control register.</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000006C</resetValue>
          <fields>
            <field>
              <name>STOP_DET_IF_MASTER_ACTIVE</name>
              <description>In Master mode:</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_FIFO_FULL_HLD_CTRL</name>
              <description>This bit controls whether I2C should
              hold the bus when the Rx FIFO is
              physically full to its RX_BUFFER_DEPTH
             </description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_EMPTY_CTRL</name>
              <description>This bit controls the generation
              of the TX_EMPTY interrupt as described
              in the I2C_RAWINTSTS register</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STOP_DET_IF_ADDRESSED</name>
              <description>In slave mode:</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLAVE_DISABLE</name>
              <description>This bit controls whether I2C has
              its slave disabled then this bit
              takes on the value of the configuration
              parameter I2C_SLAVE_DISABLE</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESTART_EN</name>
              <description>Determines whether RESTART conditions
              may be sent when acting as a master
             </description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>10BITADDR_SLAVE</name>
              <description>When acting as a slave this bit
              controls whether the I2C responds
              to 7 or 10 bit addresses</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SPEED</name>
              <description>These bits control at which speed
              the I2C operates its setting is
              relevant only if one is operating
              the I2C in master mode</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>MASTER_MODE</name>
              <description>This bit controls whether the I2C
              master is enabled</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TAR</name>
          <displayName>TAR</displayName>
          <description>I2C target address register.</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000055</resetValue>
          <fields>
            <field>
              <name>10BITADDR_MASTER</name>
              <description>This bit controls whether the I2C
              starts its transfers in 7 or 10
              bit addressing mode when acting
              as a master</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SPECIAL</name>
              <description>This bit indicates whether software
              performs a Device ID or General
              Call or START BYTE command</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GC_OR_START</name>
              <description>If bit 11 SPECIAL is set to 1 and
              bit 13 Device ID is set to 0 then
              this bit indicates whether a General
              Call or START byte command is to
              be performed by the I2C</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TAR</name>
              <description>This is the target address for
              any master transaction</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SAR</name>
          <displayName>SAR</displayName>
          <description>I2C slave address register.</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000055</resetValue>
          <fields>
            <field>
              <name>SAR</name>
              <description>The I2C_SAR holds the slave address
              when the I2C is operating as a
              slave</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>DATACMD</name>
          <displayName>DATACMD</displayName>
          <description>I2C Rx/Tx data buffer and command register.</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RESTART</name>
              <description>This bit controls whether a RESTART
              is issued before the byte is sent
              or received</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STOP</name>
              <description>This bit controls whether a STOP
              is issued after the byte is sent
              or received</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD</name>
              <description>This bit controls whether a read
              or a write is performed</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DAT</name>
              <description>This register contains the data
              to be transmitted or received on
              the I2C bus</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SSCNTH</name>
          <displayName>SSCNTH</displayName>
          <description>Standard speed I2C clock SCL high count register.</description>
          <addressOffset>0x14</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000028</resetValue>
          <fields>
            <field>
              <name>SS_SCL_HCNT</name>
              <description>This register must be set before
              any I2C bus transaction can take
              place to ensure proper I O timing
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SSCNTL</name>
          <displayName>SSCNTL</displayName>
          <description>Standard speed I2C clock SCL low count register.</description>
          <addressOffset>0x18</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000002F</resetValue>
          <fields>
            <field>
              <name>SS_SCL_LCNT</name>
              <description>This register must be set before
              any I2C bus transaction can take
              place to ensure proper I O timing
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FSCNTH</name>
          <displayName>FSCNTH</displayName>
          <description>Fast Mode or Fast Mode Plus I2C clock SCL high count register</description>
          <addressOffset>0x1C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000006</resetValue>
          <fields>
            <field>
              <name>FS_SCL_HCNT</name>
              <description>This register must be set before
              any I2C bus transaction can take
              place to ensure proper I O timing
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>FSCNTL</name>
          <displayName>FSCNTL</displayName>
          <description>Fast Mode or Fast Mode Plus I2C clock SCL low count register</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000000D</resetValue>
          <fields>
            <field>
              <name>FS_SCL_LCNT</name>
              <description>This register must be set before
              any I2C bus transaction can take
              place to ensure proper I O timing
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>INTSTS</name>
          <displayName>INTSTS</displayName>
          <description>I2C interrupt status register.</description>
          <addressOffset>0x2C</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MASTER_ON_HOLD</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of MASTER_ON_HOLD bit
             </description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESTART_DET</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of RESTART_DET bit
             </description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GEN_CALL</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of GEN_CALL bit</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>START_DET</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of START_DET bit</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STOP_DET</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of STOP_DET bit</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACTIVITY</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of ACTIVITY bit</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_DONE</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of R_RX_DONE bit</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_ABRT</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of TX_ABRT bit</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RD_REQ</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of RD_REQ bit</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_EMPTY</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of TX_EMPTY bit</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_OVER</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of TX_OVER bit</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_FULL</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of RX_FULL bit</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_OVER</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of RX_OVER bit</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_UNDER</name>
              <description>See I2C_RAWINTSTS for a detailed
              description of RX_UNDER bit</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>INTMASK</name>
          <displayName>INTMASK</displayName>
          <description>I2C interrupt mask register.</description>
          <addressOffset>0x30</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x000008FF</resetValue>
          <fields>
            <field>
              <name>M_MASTER_ON_HOLD</name>
              <description>This bit masks the R_MASTER_ON_HOLD
              interrupt in I2C_INTSTS register
             </description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_RESTART_DET</name>
              <description>This bit masks the R_RESTART_DET
              interrupt in I2C_INTSTS register
             </description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_GEN_CALL</name>
              <description>This bit masks the R_GEN_CALL interrupt
              in I2C_INTSTS register</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_START_DET</name>
              <description>This bit masks the R_START_DET
              interrupt in I2C_INTSTS register
             </description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_STOP_DET</name>
              <description>This bit masks the R_STOP_DET interrupt
              in I2C_INTSTS register</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_ACTIVITY</name>
              <description>This bit masks the R_ACTIVITY interrupt
              in I2C_INTSTS register</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_RX_DONE</name>
              <description>This bit masks the R_RX_DONE interrupt
              in I2C_INTSTS register</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_TX_ABRT</name>
              <description>This bit masks the R_TX_ABRT interrupt
              in I2C_INTSTS register</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_RD_REQ</name>
              <description>This bit masks the R_RD_REQ interrupt
              in I2C_INTSTS register</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_TX_EMPTY</name>
              <description>This bit masks the R_TX_EMPTY interrupt
              in I2C_INTSTS register</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_TX_OVER</name>
              <description>This bit masks the R_TX_OVER interrupt
              in I2C_INTSTS register</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_RX_FULL</name>
              <description>This bit masks the R_RX_FULL interrupt
              in I2C_INTSTS register</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_RX_OVER</name>
              <description>This bit masks the R_RX_OVER interrupt
              in I2C_INTSTS register</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>M_RX_UNDER</name>
              <description>This bit masks the R_RX_UNDER interrupt
              in I2C_INTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RAWINTSTS</name>
          <displayName>RAWINTSTS</displayName>
          <description>I2C raw interrupt status register. </description>
          <addressOffset>0x34</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>MASTER_ON_HOLD</name>
              <description>Indicates whether master is holding
              the bus and TX FIFO is empty</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RESTART_DET</name>
              <description>Indicates whether a RESTART condition
              has occurred on the I2C interface
              when I2C is operating in Slave
              mode and the slave is being addressed
             </description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>GEN_CALL</name>
              <description>Set only when a General Call address
              is received and it is acknowledged
             </description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>START_DET</name>
              <description>Indicates whether a START or RESTART
              condition has occurred on the I2C
              interface regardless of whether
              I2C is operating in slave or master
              mode</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STOP_DET</name>
              <description>Indicates whether a STOP condition
              has occurred on the I2C interface
              regardless of whether I2C is operating
              in slave or master mode</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACTIVITY</name>
              <description>This bit captures I2C activity
              and stays set until it is cleared
             </description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_DONE</name>
              <description>When the I2C is acting as a slave
              transmitter this bit is set to
              1 if the master does not acknowledge
              a transmitted byte</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_ABRT</name>
              <description>This bit indicates if I2C as an
              I2C transmitter is unable to complete
              the intended actions on the contents
              of the transmit FIFO</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RD_REQ</name>
              <description>This bit is set to 1 when I2C is
              acting as a slave and another I2C
              master is attempting to read data
              from I2C</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_EMPTY</name>
              <description>The behavior of the TX_EMPTY interrupt
              status differs based on the TX_EMPTY_CTRL
              selection in the I2C_CON register
             </description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_OVER</name>
              <description>Set during transmit if the transmit
              buffer is filled to I2C_TX_BUFFER_DEPTH
              and the processor attempts to issue
              another I2C command by writing
              to the I2C_DATACMD register</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_FULL</name>
              <description>Set when the receive buffer reaches
              or goes above the RX_TL threshold
              in the I2C_RXTL register</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_OVER</name>
              <description>Set if the receive buffer is completely
              filled to I2C_RX_BUFFER_DEPTH and
              an additional byte is received
              from an external I2C device</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_UNDER</name>
              <description>Set if the processor attempts to
              read the receive buffer when it
              is empty by reading from the I2C_DATACMD
              register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RXTL</name>
          <displayName>RXTL</displayName>
          <description>I2C receive FIFO threshold register.</description>
          <addressOffset>0x38</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RX_TL</name>
              <description>Receive FIFO Threshold Level.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TXTL</name>
          <displayName>TXTL</displayName>
          <description>I2C transmit FIFO threshold register.</description>
          <addressOffset>0x3C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TX_TL</name>
              <description>Transmit FIFO Threshold Level.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>INTCLR</name>
          <displayName>INTCLR</displayName>
          <description>Clear combined and individual interrupt register.</description>
          <addressOffset>0x40</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_INTR</name>
              <description>Read this register to clear the
              combined interrupt all individual
              interrupts and the I2C_TXABTSRC
              register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RXUCLR</name>
          <displayName>RXUCLR</displayName>
          <description>Clear RX_UNDER interrupt register.</description>
          <addressOffset>0x44</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_RX_UNDER</name>
              <description>Read this register to clear the
              RX_UNDER interrupt bit 0 of the
              I2C_RAWINTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RXOCLR</name>
          <displayName>RXOCLR</displayName>
          <description>Clear RX_OVER interrupt register.</description>
          <addressOffset>0x48</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_RX_OVER</name>
              <description>Read this register to clear the
              RX_OVER interrupt bit 1 of the
              I2C_RAWINTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TXOCLR</name>
          <displayName>TXOCLR</displayName>
          <description>Clear TX_OVER interrupt register.</description>
          <addressOffset>0x4C</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_TX_OVER</name>
              <description>Read this register to clear the
              TX_OVER interrupt bit 3 of the
              I2C_RAWINTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RDREQCLR</name>
          <displayName>RDREQCLR</displayName>
          <description>Clear RD_REQ interrupt register.</description>
          <addressOffset>0x50</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_RD_REQ</name>
              <description>Read this register to clear the
              RD_REQ interrupt bit 5 of the I2C_RAWINTSTS
              register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TXABTCLR</name>
          <displayName>TXABTCLR</displayName>
          <description>Clear TX_ABRT interrupt register.</description>
          <addressOffset>0x54</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_TX_ABRT</name>
              <description>Read this register to clear the
              TX_ABRT interrupt bit 6 of the
              I2C_RAWINTSTS register and the
              I2C_TXABTSRC register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RXDONECLR</name>
          <displayName>RXDONECLR</displayName>
          <description>Clear RX_DONE interrupt register.</description>
          <addressOffset>0x58</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_RX_DONE</name>
              <description>Read this register to clear the
              RX_DONE interrupt bit 7 of the
              I2C_RAWINTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ACTCLR</name>
          <displayName>ACTCLR</displayName>
          <description>Clear ACTIVITY interrupt register.</description>
          <addressOffset>0x5C</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_ACTIVITY</name>
              <description>Reading this register clears the
              ACTIVITY interrupt if the I2C is
              not active anymore</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STOPDETCLR</name>
          <displayName>STOPDETCLR</displayName>
          <description>Clear STOP_DET interrupt register.</description>
          <addressOffset>0x60</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_STOP_DET</name>
              <description>Read this register to clear the
              STOP_DET interrupt bit 9 of the
              I2C_RAWINTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STARTDETCLR</name>
          <displayName>STARTDETCLR</displayName>
          <description>Clear START_DET interrupt register.</description>
          <addressOffset>0x64</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_START_DET</name>
              <description>Read this register to clear the
              START_DET interrupt bit 10 of the
              I2C_RAWINTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GENCALLCLR</name>
          <displayName>GENCALLCLR</displayName>
          <description>Clear GEN_CALL interrupt register.</description>
          <addressOffset>0x68</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_GEN_CALL</name>
              <description>Read this register to clear the
              GEN_CALL interrupt bit 11 of I2C_RAWINTSTS
              register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ENABLE</name>
          <displayName>ENABLE</displayName>
          <description>I2C enable register.</description>
          <addressOffset>0x6C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ABORT</name>
              <description>When set the controller initiates
              the transfer abort</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ENABLE</name>
              <description>Controls whether the I2C is enabled.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <displayName>STATUS</displayName>
          <description>I2C status register.</description>
          <addressOffset>0x70</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000006</resetValue>
          <fields>
            <field>
              <name>SLV_HOLD_RX_FIFO_FULL</name>
              <description>This bit indicates the BUS Hold
              in Slave mode due to Rx FIFO is
              Full and an additional byte has
              been received</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLV_HOLD_TX_FIFO_EMPTY</name>
              <description>This bit indicates the BUS Hold
              in Slave mode for the Read request
              when the Tx FIFO is empty</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MST_HOLD_RX_FIFO_FULL</name>
              <description>This bit indicates the BUS Hold
              in Master mode due to Rx FIFO is
              Full and additional byte has been
              received</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MST_HOLD_TX_FIFO_EMPTY</name>
              <description>The I2C master stalls the write
              transfer when Tx FIFO is empty
              and the the last byte does not
              have the Stop bit set</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLV_ACTIVITY</name>
              <description>Slave FSM Activity Status</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MST_ACTIVITY</name>
              <description>Master FSM Activity Status</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RFF</name>
              <description>Receive FIFO Completely Full</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RFNE</name>
              <description>Receive FIFO Not Empty</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TFE</name>
              <description>Transmit FIFO Completely Empty
             </description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TFNF</name>
              <description>Transmit FIFO Not Full</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ACTIVITY</name>
              <description>I2C Activity Status.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TXFLR</name>
          <displayName>TXFLR</displayName>
          <description>I2C transmit FIFO level register.</description>
          <addressOffset>0x74</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TXFLR</name>
              <description>Transmit FIFO Level</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RXFLR</name>
          <displayName>RXFLR</displayName>
          <description>I2C Receive FIFO Level Register.</description>
          <addressOffset>0x78</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RXFLR</name>
              <description>Receive FIFO Level</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SDAHOLD</name>
          <displayName>SDAHOLD</displayName>
          <description>I2C SDA hold time length register.</description>
          <addressOffset>0x7C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000001</resetValue>
          <fields>
            <field>
              <name>I2C_SDA_RX_HOLD</name>
              <description>Sets the required SDA hold time
              in units of ic_clk period when
              I2C acts as a receiver</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>I2C_SDA_TX_HOLD</name>
              <description>Sets the required SDA hold time
              in units of ic_clk period when
              I2C acts as a transmitter</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TXABTSRC</name>
          <displayName>TXABTSRC</displayName>
          <description>I2C transmit abort source register.</description>
          <addressOffset>0x80</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TX_FLUSH_CNT</name>
              <description>This field indicates the number
              of Tx FIFO Data Commands which
              are flushed due to TX_ABRT interrupt
             </description>
              <bitOffset>23</bitOffset>
              <bitWidth>9</bitWidth>
            </field>
            <field>
              <name>ABRT_USER_ABRT</name>
              <description>This is a master mode only bit
             </description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_SLVRD_INTX</name>
              <description>1 When the processor side responds
              to a slave mode request for data
              to be transmitted to a remote master
              and user writes a 1 in CMD bit
              8 of I2C_DATACMD register</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_SLV_ARBLOST</name>
              <description>This field indicates that a Slave
              has lost the bus while transmitting
              data to a remote master</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_SLVFLUSH_TXFIFO</name>
              <description>This field specifies that the Slave
              has received a read command and
              some data exists in the TX FIFO
              so the slave issues a TX_ABRT interrupt
              to flush old data in TX FIFO</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ARB_LOST</name>
              <description>This field specifies that the Master
              has lost arbitration or if I2C_TXABTSRC
              14 is also set then the slave transmitter
              has lost arbitration</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_MASTER_DIS</name>
              <description>This field indicates that the User
              tries to initiate a Master operation
              with the Master mode disabled</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_10B_RD_NORSTRT</name>
              <description>This field indicates that the restart
              is disabled I2C_RESTART_EN bit
              I2C_CON 5 0 and the master sends
              a read command in 10 bit addressing
              mode</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_SBYTE_NORSTRT</name>
              <description>To clear Bit 9 the source of the
              ABRT_SBYTE_NORSTRT must be fixed
              first restart must be enabled I2C_CON
              5 1 the SPECIAL bit must be cleared
              I2C_TAR 11 or the GC_OR_START bit
              must be cleared I2C_TAR 10 </description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_HS_NORSTRT</name>
              <description>This field indicates that the restart
              is disabled I2C_RESTART_EN bit
              I2C_CON 5 0 and the user is trying
              to use the master to transfer data
              in High Speed mode</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_SBYTE_ACKDET</name>
              <description>This field indicates that the Master
              has sent a START Byte and the START
              Byte was acknowledged wrong behavior
              </description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_HS_ACKDET</name>
              <description>This field indicates that the Master
              is in High Speed mode and the High
              Speed Master code was acknowledged
              wrong behavior </description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_GCALL_READ</name>
              <description>This field indicates that I2C in
              the master mode has sent a General
              Call but the user programmed the
              byte following the General Call
              to be a read from the bus I2C_DATACMD
              9 is set to 1 </description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_GCALL_NOACK</name>
              <description>This field indicates that I2C in
              master mode has sent a General
              Call and no slave on the bus acknowledged
              the General Call</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_TXDATA_NOACK</name>
              <description>This field indicates the master
              mode only bit</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_10ADDR2_NOACK</name>
              <description>This field indicates that the Master
              is in 10 bit address mode and that
              the second address byte of the
              10 bit address was not acknowledged
              by any slave</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_10ADDR1_NOACK</name>
              <description>This field indicates that the Master
              is in 10 bit address mode and the
              first 10 bit address byte was not
              acknowledged by any slave</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ABRT_7B_ADDR_NOACK</name>
              <description>This field indicates that the Master
              is in 7 bit addressing mode and
              the address sent was not acknowledged
              by any slave</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SDASETUP</name>
          <displayName>SDASETUP</displayName>
          <description>I2C SDA setup register.</description>
          <addressOffset>0x94</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000064</resetValue>
          <fields>
            <field>
              <name>SDA_SETUP</name>
              <description>SDA Setup</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ACKGC</name>
          <displayName>ACKGC</displayName>
          <description>I2C ACK General Call register.</description>
          <addressOffset>0x98</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000001</resetValue>
          <fields>
            <field>
              <name>ACK_GEN_CALL</name>
              <description>ACK General Call</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ENSTS</name>
          <displayName>ENSTS</displayName>
          <description>I2C enable status register.</description>
          <addressOffset>0x9C</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SLV_RX_DATA_LOST</name>
              <description>Slave Received Data Lost</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLV_DISABLED_WHILE_BUSY</name>
              <description>Slave Disabled While Busy Transmit
              Receive </description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>I2C_EN</name>
              <description>ic_en Status</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SPKLEN</name>
          <displayName>SPKLEN</displayName>
          <description>I2C SS, FS or FM+ spike suppression limit register</description>
          <addressOffset>0xA0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000001</resetValue>
          <fields>
            <field>
              <name>FS_SPKLEN</name>
              <description>This register must be set before
              any I2C bus transaction can take
              place to ensure stable operation
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RESDETCLR</name>
          <displayName>RESDETCLR</displayName>
          <description>Clear RESTART_DET interrupt register.</description>
          <addressOffset>0xA8</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CLR_RESTART_DET</name>
              <description>Read this register to clear the
              RESTART_DET interrupt bit 12 of
              I2C_RAWINTSTS register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>BSPI0</name>
      <description>BSPI0 Peripheral Interface</description>
      <groupName>BSPI</groupName>
      <baseAddress>0x41020000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x800</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CTRL</name>
          <displayName>CTRL</displayName>
          <description>BSPI control Register</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BSPIEN</name>
              <description>BSPI enable.</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>LSBF</name>
              <description>BSPI LSB control.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSPIRST</name>
              <description>BSPI software reset.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CSGPIO</name>
              <description>The control owner of BSPICS.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SWAP</name>
              <description>BSPI MISO/MOSI swap control.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>MOD</name>
              <description>BSPI Mode Selection register.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SCKPHA</name>
              <description>BSPI clock phase.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SCKPOL</name>
              <description>BSPI clock polarity.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SCKSEL</name>
              <description>Master mode clock selection.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>TXSTS</name>
          <displayName>TXSTS</displayName>
          <description>BSPI transmit status register</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00008200</resetValue>
          <fields>
            <field>
              <name>WMASK</name>
              <description>Write mask bit</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
            <field>
              <name>BSPITXIF</name>
              <description>BSPI Transmit Interrupt flag. </description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BSPITXIEN</name>
              <description>BSPI Transmit Interrupt Enable.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXEMPTY</name>
              <description>Transmot FIFO empty register.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFUR</name>
              <description>Transmit FIFO under run register.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TXFLEV</name>
              <description>Transmit FIFO interrupt level register.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
