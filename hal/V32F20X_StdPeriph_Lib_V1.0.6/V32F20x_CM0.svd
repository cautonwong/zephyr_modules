              <name>FBSLIP</name>
              <description>Feedback cycle slip output (CLKOUT frequency low)</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RFSLIP</name>
