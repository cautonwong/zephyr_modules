          <access>read-write</access>
          <resetValue>0x000752C0</resetValue>
          <fields>
            <field>
              <name>BYPASS</name>
              <description>Reference to output bypass mode</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKOD</name>
              <description>A 4 bit bus that selects the values
