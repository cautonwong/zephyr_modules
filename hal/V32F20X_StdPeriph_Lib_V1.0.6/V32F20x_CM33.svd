              <name>TBS</name>
              <description>Transmit Buffer Status</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DOS</name>
              <description>Data Overrun Status</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RBS</name>
              <description>Receive Buffer Status</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>RDCYC_IR</name>
          <displayName>RDCYC_IR</displayName>
          <description>Interrupt register</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BEI</name>
              <description>Set when the MCAN2 detects an error
              on the CAN bus provided the BEIE
              bit IER</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ALI</name>
              <description>Set when the MCAN2 loses arbitration
              and becomes a receiver provided
              the ALIE bit IER</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EPI</name>
              <description>Set when the MCAN2 re enters error
              active state after being in error
             </description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WUI</name>
              <description>Set when bus activity is detected
              while the CAN controller is sleeping
              provided the WUIE bit IER</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DOI</name>
              <description>Set on a 0 to 1 transition of the
              Data Overrun Status bit SR</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EI</name>
              <description>Set on every change set or clear
              of either the Bus Status or Error
              Status bits SR</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TI</name>
              <description>Set whenever the Transmit Buffer
              Status SR</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RI</name>
              <description>Set whenever the Receive Buffer
              contains one or more messages provided
              the RIE bit IER</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
