    <peripheral>
      <name>FLASHA</name>
      <description>FLASHA Peripheral Interface</description>
      <groupName>FLASH</groupName>
      <baseAddress>0x40208000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x4000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CACHE_CTRL</name>
          <displayName>CACHE_CTRL</displayName>
          <description>Flash cache Control register.</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000040</resetValue>
          <fields>
            <field>
              <name>OPT_EN</name>
              <description>Cache Performance Optimization enable control</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>STATISTIC_EN</name>
              <description>Statistics logic enable control</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_PROFETCH</name>
              <description>Cache Pre-fetch enable control</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_MAN_INV</name>
              <description>Cache Invalidate control</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SET_MAN_POW</name>
              <description>Power control</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>POW_REQ</name>
              <description>Manual SRAM power request.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INV_REQ</name>
              <description>Manual invalidate request</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EN</name>
              <description>Cache enable control</description>
