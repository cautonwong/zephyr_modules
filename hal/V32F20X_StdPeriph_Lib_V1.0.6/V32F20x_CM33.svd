          <name>STS</name>
          <displayName>STS</displayName>
          <description>PMU status register</description>
          <addressOffset>0x1C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WDTRST_CM33_0</name>
              <description>This bit indicated if the last
              interrupt is cause by watch dog
              timer</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>WDTRST_CM33_1</name>
              <description>This bit indicated if the last
