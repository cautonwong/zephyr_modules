    <peripheral>
      <name>ENCENG</name>
      <description>ENCENG Peripheral Interface</description>
      <groupName>ENCENG</groupName>
      <baseAddress>0x40206000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x800</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CFG</name>
          <displayName>CFG</displayName>
          <description>ENCENG configuration register.</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>HMAC_KEY_SIZE</name>
              <description>The key size of HMAC, unit in word:</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>KEY_SWAP</name>
              <description>If 1 will swap the key input bytes
              in each word The default is byte
              order so LSB is 1st order but allows
              swapping to MSB is first</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_SWAP</name>
              <description>If 1 will swap bytes in the word
              for hash and encryption The default
              is byte order so LSB is 1st order
              but allows swapping to MSB is first
             </description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
