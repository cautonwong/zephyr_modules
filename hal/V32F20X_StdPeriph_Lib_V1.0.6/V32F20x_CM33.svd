        <register>
          <name>GFC_MASKED_STATUS</name>
          <displayName>GFC_MASKED_STATUS</displayName>
          <description>GFC interrupt status register that shows if each interrupt is pending and is the cause of the interrupt line being asserted</description>
          <addressOffset>0x2010</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CMD_REJECT_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_REJECT_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_FAIL_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_FAIL_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_SUCCESS_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_SUCCESS_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD_ACCEPT_IRQ</name>
              <description>When this bit reads 1 it means
              that CMD_ACCEPT_IRQ is the cause
              of the interrupt line being asserted
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>GFC_CTRL</name>
          <displayName>GFC_CTRL</displayName>
          <description>GFC control register for initiating Flash accesses</description>
          <addressOffset>0x2014</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ABORT</name>
              <description>Abort currently ongoing command
              that is initiated towards the Flash
              from the APB interface</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CMD</name>
              <description>Initiate a command to the Flash
              for the address that is stored
              in the ADDR register and with the
              data that are stored in DATA0 register
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
          </fields>
        </register>
        <register>
