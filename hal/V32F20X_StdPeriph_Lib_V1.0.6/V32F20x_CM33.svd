    <peripheral derivedFrom="RETRAM">
      <name>SEC_RETRAM</name>
      <baseAddress>0x50100000</baseAddress>
    </peripheral>
    <peripheral>
      <name>PMU</name>
      <description>PMU Peripheral Interface</description>
      <groupName>PMU</groupName>
      <baseAddress>0x40100800</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x800</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CM0DSLPEN</name>
          <displayName>CM0DSLPEN</displayName>
          <description>CM0 deep sleep enable register</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKU</name>
              <description>Current wake up signal this bit
              reflects the CM0 wake up status
              receive by PMU controller programmer
              must make sure this bit is 0 before
              entering deep sleep mode otherwise
              the system will wake up immediately
              because of non clear wake up event
             </description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSLEEP</name>
              <description>This bit indicates the CM0 deep
              sleep mode has been entry</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CM0DSLPPSWD</name>
          <displayName>CM0DSLPPSWD</displayName>
          <description>CM0 deep sleep password register</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>UNLOCK</name>
              <description>This bit indicates the CM0 deep
              sleep mode has unlocked and is
              ready to entry deep sleep mode
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CM0SLPEN</name>
          <displayName>CM0SLPEN</displayName>
          <description>CM0 sleep enable register</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKU</name>
              <description>Current wake up signal this bit
              reflects the CM0 wake up status
              receive by PMU controller programmer
              must make sure this bit is 0 before
              entering sleep mode otherwise the
              system will wake up immediately
              because of non clear wake up event
             </description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLEEP</name>
              <description>This bit indicates the CM0 sleep
              mode has unlocked and is ready
              to entry sleep mode</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CM33DSLPEN</name>
          <displayName>CM33DSLPEN</displayName>
          <description>CM33 deep sleep enable register</description>
          <addressOffset>0xC</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKU</name>
              <description>Current wake up signal this bit
              reflects the CM33 wake up status
              receive by PMU controller programmer
              must make sure this bit is 0 before
              entering deep sleep mode otherwise
              the system will wake up immediately
              because of non clear wake up event
             </description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSLEEP</name>
              <description>This bit indicates CM0 control
              the CM33 enter deep sleep mode
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CM33DSLPPSWD</name>
          <displayName>CM33DSLPPSWD</displayName>
          <description>CM33 deep sleep password register</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKU</name>
              <description>Current wake up signal this bit
              reflects the CM33 wake up status
              receive by PMU controller programmer
              must make sure this bit is 0 before
              entering deep sleep mode otherwise
              the system will wake up immediately
              because of non clear wake up event
             </description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSLEEP</name>
              <description>This bit indicates CM0 control
              the CM33 enter deep sleep mode
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CM33SLPEN</name>
          <displayName>CM33SLPEN</displayName>
          <description>CM33 sleep enable register</description>
          <addressOffset>0x14</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKU</name>
              <description>Current wake up signal this bit
              reflects the CM33 wake up status
              receive by PMU controller programmer
              must make sure this bit is 0 before
              entering deep sleep mode otherwise
              the system will wake up immediately
              because of non clear wake up event
             </description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLEEP</name>
              <description>This bit indicates the CM33 sleep
              mode has unlocked and is ready
              to entry sleep mode</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL</name>
          <displayName>CTRL</displayName>
          <description>PMU control register</description>
          <addressOffset>0x18</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CM33_WKUINTEN</name>
              <description>CM33 Wake up interrupt enable.</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CM33CLKAUTO</name>
              <description>Whether to make the BGP1 RCH1 PLLL
              and PLLH power down when CM33 in
              deep sleep or sleep mode</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CM0CLKAUTO</name>
              <description>Whether to make the BGP1 RCH1 PLLL
              and PLLH power down when CM0 in
              deep sleep or sleep mode</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>INT_IOWKU_EN</name>
              <description>Enable interrupt of the io wakeup source </description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CM0_WKUINTEN</name>
              <description>CM0 Wake up interrupt enable.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>NOWAITLOCK</name>
              <description>Override the PLLH PLLL Lock from
              Analog module when this bit set
             </description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CM33_WKU_SRC_EB</name>
              <description>CM33 wake up source enable: </description>
              <bitOffset>8</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
            <field>
              <name>CM0_WKU_SRC_EB</name>
              <description>CM0 wake up source enable: </description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
            </field>
          </fields>
        </register>
