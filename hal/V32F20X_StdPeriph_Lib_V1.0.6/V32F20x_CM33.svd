              <description>When CH1_SYN_FAILED_NUM is bigger
              than 5 this field will be set</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH0_SYN_FAILED</name>
              <description>When CH0_SYN_FAILED_NUM is bigger
              than 5 this field will be set</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>FIFO_STS</name>
              <description>FIFO STATUS</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>INT_MASK</name>
          <displayName>INT_MASK</displayName>
          <description>INT_MASK</description>
          <addressOffset>0x10</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ERR_OVF_MSK</name>
              <description>The interrupt mask of ERR_OVF_MSK</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ERR_UDF_MSK</name>
              <description>The interrupt mask of ERR_UDF</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH1_SYN_FAILED_MASK</name>
              <description>The interrupt mask of CH1_SYN_FAILED</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CH0_SYN_FAILED_MASK</name>
              <description>The interrupt mask of CH0_SYN_FAILED:</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CH_DATA</name>
          <displayName>CH_DATA</displayName>
          <description>CH_DATA</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>CH_DATA</name>
              <description>Converted parallel data of Channel 0</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral derivedFrom="EADC">
      <name>SEC_EADC</name>
      <baseAddress>0x500A0800</baseAddress>
    </peripheral>
    <peripheral>
      <name>ADC0</name>
      <description>ADC0 Peripheral Interface</description>
      <groupName>ADC</groupName>
      <baseAddress>0x400A1000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>STS</name>
          <displayName>STS</displayName>
          <description>ADC status register</description>
          <addressOffset>0x0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKP</name>
              <description>This bit is set by hardware when
              the converted voltage crosses the
              values programmed in the ADC_WLTR
              and ADC_WHTR registers and WKP
              is set</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMA_MISS</name>
              <description>This bit is set when DMA has not
              read the data when the data is
              overwritten</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JEC_INTSTS</name>
              <description>Interrupt status</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AWD_INTSTS</name>
              <description>Interrupt status</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EC_INTSTS</name>
              <description>Interrupt status</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RSRT</name>
              <description>This bit is set by hardware when
              regular channel conversion starts
             </description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JSTR</name>
              <description>This bit is set by hardware when
              injected channel group conversion
              starts</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JEC</name>
              <description>This bit is set by hardware at
              the end of all injected group channel
              conversion</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EC</name>
              <description>This bit is set by hardware at
              the end of a group channel conversion
              only regular </description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AWD</name>
              <description>This bit is set by hardware when
              the converted voltage crosses the
              values programmed in the ADC_WLTR
              and ADC_WHTR registers</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <displayName>CTRL1</displayName>
          <description>ADC control register 1</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>WKPEN</name>
              <description>Wake up enable.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AWDEN</name>
              <description>This bit is set/reset by software.</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JAWDEN</name>
              <description>This bit is set/reset by software</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DUALMOD</name>
              <description>These bits are written by software
              to select the operating mode</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>DISN</name>
              <description>These bits are written by software
              to define the number of regular
              channels to be converted in discontinuous
              mode after receiving an external
              trigger</description>
              <bitOffset>13</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>JDISEN</name>
              <description>This bit set and cleared by software
              to enable disable discontinuous
              mode on injected group channels
             </description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RDISEN</name>
              <description>This bit set and cleared by software
              to enable disable Discontinuous
              mode on regular channels</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JAUT</name>
              <description>This bit set and cleared by software
              to enable disable automatic injected
              group conversion after regular
              group conversion</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AWDSGE</name>
              <description>This bit set and cleared by software
              to enable disable the analog watchdog
              on the channel identified by the
              AWDCH 4 0 bits</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SCN</name>
              <description>This bit is set and cleared by
              software to enable disable Scan
              mode</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JECIE</name>
              <description>This bit is set and cleared by
              software to enable disable the
              end of conversion interrupt for
              injected channels</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AWDIE</name>
              <description>This bit is set and cleared by
              software to enable disable the
              analog watchdog interrupt</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ECIE</name>
              <description>This bit is set and cleared by
              software to enable disable the
              end of Conversion interrupt</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AWDCH</name>
              <description>These bits are set and cleared
              by software</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL2</name>
          <displayName>CTRL2</displayName>
          <description>ADC control register 2</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SWSTR</name>
              <description>This bit is set by software to
              start conversion and cleared by
              hardware as soon as conversion
              starts</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JSWSTR</name>
              <description>This bit is set by software and
              cleared by software or by hardware
              as soon as the conversion starts
             </description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EXTTRIG</name>
              <description>This bit is set and cleared by
              software to enable disable the
              external trigger used to start
              conversion of a regular channel
              group</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>EXSEL</name>
              <description>These bits select the external
              event used to trigger the start
              of conversion of a regular group
              </description>
              <bitOffset>17</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>JEXTTRIG</name>
              <description>This bit is set and cleared by
              software to enable disable the
              external trigger used to start
              conversion of an injected channel
              group</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JEXSEL</name>
              <description>These bits select the external
              event used to trigger the start
              of conversion of an injected group
              For ADC0 and ADC1 the assigned
              triggers are </description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
            </field>
            <field>
              <name>DALIGN</name>
              <description>This bit is set and cleared by software.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DMAEN</name>
              <description>This bit is set and cleared by software.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>JBTIME_EN</name>
              <description>This bit combine with JEXSEL to
              decide the trigger source of injected
             </description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BTIME_EN</name>
              <description>This bit combine with EXSEL to
              decide the trigger source of regular
             </description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RSTCAL</name>
              <description>This bit is set by software and
              cleared by hardware</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CAL</name>
              <description>This bit is set by software to
              start the calibration</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CON</name>
              <description>This bit is set and cleared by
              software</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>ADON</name>
              <description>This bit is set and cleared by
              software</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SMPT1</name>
          <displayName>SMPT1</displayName>
