              <name>EXIST32K</name>
              <description>32K XTAL exist status register
             </description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CM0PWRSTS</name>
