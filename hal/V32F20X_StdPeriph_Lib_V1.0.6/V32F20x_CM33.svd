        <register>
          <name>IMR</name>
          <displayName>IMR</displayName>
          <description>RNG interrupt mask register.</description>
          <addressOffset>0x100</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>VN_ERR_MASK</name>
              <description>This bit masks the VN_ERR interrupt
              signal from RNG_ISR register</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRNGT_ERR_MASK</name>
              <description>This bit masks the CRNGT_ERR interrupt
              signal from RNG_ISR register</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AUTOCORR_ERR_MASK</name>
              <description>This bit masks the AUTOCORR_ERR
              interrupt signal from RNG_ISR register
             </description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_VALID_MASK</name>
              <description>This bit masks the DATA_VALID interrupt
              signal from RNG_ISR register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ISR</name>
          <displayName>ISR</displayName>
          <description>RNG interrupt status register.</description>
          <addressOffset>0x104</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>VN_ERR</name>
              <description>A Von Neumann error occurs if 32
              consecutive collected bits are
              identical that is 32 zeros or 32
              ones</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CRNGT_ERR</name>
              <description>When set to 1 it indicates a Continuous
              Random Number Generation Testing
              CRNGT error in the TRNG test failed
             </description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>AUTOCORR_ERR</name>
              <description>When set to 1 it indicates that
              the Autocorrelation test failed
              four times in a row</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DATA_VALID</name>
              <description>Set to 1 when 192 bits have been
              collected in the RNG and the DATA0
              5 registers are ready to be read
             </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ICR</name>
          <displayName>ICR</displayName>
          <description>RNG interrupt clear register.</description>
          <addressOffset>0x108</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>VN_ERR</name>
