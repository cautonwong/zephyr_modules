          <addressOffset>0x200C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000020</resetValue>
          <fields>
            <field>
              <name>CMD_REJECT_STS_CLR</name>
              <description>Clears the status of the CMD_REJECT_IRQ bit.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
