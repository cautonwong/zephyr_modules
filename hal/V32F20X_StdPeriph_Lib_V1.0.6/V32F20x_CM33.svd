              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>FSM</name>
              <description>Frame start delimiter mask</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CROP_START</name>
          <displayName>CROP_START</displayName>
          <description>DCMI crop window start register</description>
          <addressOffset>0x20</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>VO</name>
              <description>start Line number to be captured, previous line</description>
              <bitOffset>16</bitOffset>
              <bitWidth>13</bitWidth>
            </field>
            <field>
              <name>HO</name>
              <description>the number of pixel clocks to skip
