              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>LE</name>
              <description>Line end delimiter</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>LS</name>
              <description>Line start delimiter</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>FS</name>
              <description>Frame start delimiter</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>ESC_MASK</name>
          <displayName>ESC_MASK</displayName>
          <description>DCMI embedded code mask register</description>
          <addressOffset>0x1C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FEM</name>
              <description>Frame end delimiter mask</description>
