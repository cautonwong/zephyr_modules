    <peripheral>
      <name>ISO78160</name>
      <description>ISO78160 Peripheral Interface</description>
      <groupName>ISO7816</groupName>
      <baseAddress>0x40040000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>BAUDDIVL</name>
          <displayName>BAUDDIVL</displayName>
          <description>ISO78160 baud-rate low byte register.</description>
          <addressOffset>0x4</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BAUDDIVL</name>
              <description>Low byte of baud-rate divider.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>BAUDDIVH</name>
          <displayName>BAUDDIVH</displayName>
          <description>ISO78160 baud-rate high byte register.</description>
          <addressOffset>0x8</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>BAUDDIVH</name>
              <description>High byte of baud rate divider
