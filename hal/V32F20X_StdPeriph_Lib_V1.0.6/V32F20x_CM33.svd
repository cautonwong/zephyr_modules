        <register>
          <name>WAITCYCLE</name>
          <displayName>WAITCYCLE</displayName>
          <description>PMU_WAITCYCLE</description>
          <addressOffset>0x2C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00022222</resetValue>
          <fields>
            <field>
              <name>RST_DLY_CYCLE</name>
              <description>Assert additional reset delay time
              to ensure CM0 flash wakeup timing
              5us </description>
              <bitOffset>20</bitOffset>
              <bitWidth>9</bitWidth>
            </field>
            <field>
              <name>PWG_CYCLE</name>
              <description>Power gate cycle count this register
              control the power gate wait time
              when a wake up even is received
             </description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>CKG_CYCLE</name>
              <description>clkgate wait cycle count this register
              control the clkgate state wait
              time</description>
              <bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>PWUP_CYCLE</name>
              <description>Power up cycle count this register
              control the power up wait time
              when a wake up even is received
             </description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>RST_CYCLE</name>
              <description>RST assert or de assert cycle count
              this register control the RST state
              wait time</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ISO_CYCLE</name>
              <description>ISO on or off cycle count this
              register control the isolation
              state wait time</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
          </fields>
        </register>
