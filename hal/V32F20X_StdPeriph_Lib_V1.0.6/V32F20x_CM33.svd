              from the raw converted data when
              converting injected channels</description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>JOFS4</name>
          <displayName>JOFS4</displayName>
