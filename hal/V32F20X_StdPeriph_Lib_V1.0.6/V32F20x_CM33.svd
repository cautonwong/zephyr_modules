              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLPWKUCOMP</name>
              <description>This register is used to indicate
              if the previous wake up source
              from sleep mode is from Analog
              module be compare</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLPWKUIO</name>
              <description>This register is used to indicate
              if the previous wakeup source from
              sleep mode is from IO wake up</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLPWKUTIMER</name>
              <description>This register is used to indicate
              if the previous wakeup source from
              sleep mode is from timer</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLPWKUU32K0</name>
              <description>This register is used to indicate
              if the previous wakeup source from
              sleep mode is from UART32K 0 module
             </description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLPWKUU32K1</name>
              <description>This register is used to indicate
              if the previous wake up source
              from deep sleep mode is from UART32K
              1 module</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>SLPWKUXTAL</name>
              <description>This register is used to indicate
              if the previous wake</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSLPWKURTC</name>
              <description>This register is used to indicate
              if the previous wake up source
              from deep sleep mode is from RTC
              module</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSLPWKUCOMP</name>
              <description>This register is used to indicate
              if the previous wake up source
              from deep sleep mode is from Analog
              module be compare</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>DSLPWKUIO</name>
              <description>This register is used to indicate
              if the previous wake up source
              from deep sleep mode is from IO
              wakeup</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
