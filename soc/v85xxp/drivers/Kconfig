# Professional Drivers Kconfig for V85XXP

menu "V85XXP Drivers"
    depends on SOC_SERIES_V85XXP

# 1. Foundation Infrastructure
source "drivers/clock_control/Kconfig"
source "drivers/pinctrl/Kconfig"
source "drivers/dma/Kconfig"

# 2. IO & Bus Drivers
config V85XXP_GPIO
    bool "V85XXP GPIO Driver"
    default y
    depends on DT_HAS_V85XXP_GPIO_ENABLED
    select GPIO
    help
      Enable support for Vango V85XXP GPIO controller.

config V85XXP_UART
    bool "V85XXP UART Driver"
    default y
    depends on DT_HAS_V85XXP_UART_ENABLED
    select SERIAL_HAS_DRIVER
    select SERIAL_SUPPORT_INTERRUPT
    help
      Enable support for Vango V85XXP UART.

config I2C_V85XXP
    bool "V85XXP I2C Driver"
    default y
    depends on DT_HAS_V85XXP_I2C_ENABLED
    select I2C
    help
      Enable support for Vango V85XXP I2C.

config SPI_V85XXP
    bool "V85XXP SPI Driver"
    default y
    depends on DT_HAS_V85XXP_SPI_ENABLED
    select SPI
    help
      Enable support for Vango V85XXP SPI.

# 3. Dedicated Communication
config V85XXP_ISO7816
    bool "V85XXP ISO7816 Driver"
    default y
    depends on DT_HAS_V85XXP_ISO7816_ENABLED
    help
      Enable support for Vango V85XXP ISO7816 Smart Card interface.

# 4. Analog & Timers
config ADC_V85XXP
    bool "V85XXP ADC Driver"
    default y
    depends on DT_HAS_V85XXP_ADC_ENABLED
    select ADC
    help
      Enable support for Vango V85XXP ADC.

config PWM_V85XXP
    bool "V85XXP PWM Driver"
    default y
    depends on DT_HAS_V85XXP_PWM_ENABLED
    select PWM
    help
      Enable support for Vango V85XXP PWM.

config RTC_V85XXP
    bool "V85XXP RTC Driver"
    default y
    depends on DT_HAS_V85XXP_RTC_ENABLED
    select RTC
    help
      Enable support for Vango V85XXP RTC.

config COUNTER_V85XXP_TMR
    bool "V85XXP Counter Driver"
    default y
    depends on DT_HAS_V85XXP_TMR_COUNTER_ENABLED
    select COUNTER
    help
      Enable support for Vango V85XXP Timer as Counter.

# 5. System & Graphics
config LCD_V85XXP
    bool "V85XXP LCD Driver"
    default y
    depends on DT_HAS_V85XXP_LCD_ENABLED
    help
      Enable support for Vango V85XXP Segment LCD Controller.

config CRYPT_V85XXP
    bool "V85XXP CRYPT Driver"
    default y
    depends on DT_HAS_V85XXP_CRYPT_ENABLED
    help
      Enable support for Vango V85XXP Cryptographic Accelerator.

source "drivers/watchdog/Kconfig"
source "drivers/flash/Kconfig"

endmenu
source "drivers/analog/Kconfig"
