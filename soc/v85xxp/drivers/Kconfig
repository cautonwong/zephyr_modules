# Professional Drivers Kconfig for V85XXP
# Using strict rsource for hierarchical isolation

menu "V85XXP Drivers"
    depends on SOC_SERIES_V85XXP

# 1. Foundation Infrastructure (Strict relative inclusion)
rsource "clock_control/Kconfig"
rsource "pinctrl/Kconfig"
rsource "dma/Kconfig"

# 2. IO & Bus Drivers
config V85XXP_GPIO
    bool "V85XXP GPIO Driver"
    default y
    depends on DT_HAS_V85XXP_GPIO_ENABLED
    select GPIO
    help
      Enable support for Vango V85XXP GPIO controller.

config V85XXP_UART
    bool "V85XXP UART Driver"
    default y
    depends on DT_HAS_V85XXP_UART_ENABLED
    select SERIAL_HAS_DRIVER
    select SERIAL_SUPPORT_INTERRUPT
    help
      Enable support for Vango V85XXP UART.

config I2C_V85XXP
    bool "V85XXP I2C Driver"
    default y
    depends on DT_HAS_V85XXP_I2C_ENABLED
    select I2C
    help
      Enable support for Vango V85XXP I2C.

config SPI_V85XXP
    bool "V85XXP SPI Driver"
    default y
    depends on DT_HAS_V85XXP_SPI_ENABLED
    select SPI
    help
      Enable support for Vango V85XXP SPI.

# 3. Analog & Timers
config ADC_V85XXP
    bool "V85XXP ADC Driver"
    default y
    depends on DT_HAS_V85XXP_ADC_ENABLED
    select ADC
    help
      Enable support for Vango V85XXP ADC.

config PWM_V85XXP
    bool "V85XXP PWM Driver"
    default y
    depends on DT_HAS_V85XXP_PWM_ENABLED
    select PWM
    help
      Enable support for Vango V85XXP PWM.

rsource "watchdog/Kconfig"
rsource "flash/Kconfig"
rsource "analog/Kconfig"

endmenu
