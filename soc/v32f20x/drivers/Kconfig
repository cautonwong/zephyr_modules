# Professional Drivers Kconfig for V32F20X

menu "V32F20X Drivers"
    depends on SOC_SERIES_V32F20X

# 1. Foundation Infrastructure
source "drivers/clock_control/Kconfig"
source "drivers/pinctrl/Kconfig"
source "drivers/reset/Kconfig"
source "drivers/dma/Kconfig"

# 2. IO & Bus Drivers
config V32F20X_GPIO
    bool "V32F20X GPIO Driver"
    default y
    depends on DT_HAS_VANGO_V32F20X_GPIO_ENABLED
    select GPIO
    help
      Enable support for Vango V32F20X GPIO controller.

config V32F20X_UART
    bool "V32F20X UART Driver"
    default y
    depends on DT_HAS_VANGO_V32F20X_UART_ENABLED
    select SERIAL_HAS_DRIVER
    select SERIAL_SUPPORT_INTERRUPT
    help
      Enable support for Vango V32F20X UART.

config I2C_V32F20X
    bool "V32F20X I2C Driver"
    default y
    depends on DT_HAS_VANGO_V32F20X_I2C_ENABLED
    select I2C
    help
      Enable support for Vango V32F20X I2C.

config SPI_V32F20X
    bool "V32F20X SPI Driver"
    default y
    depends on DT_HAS_VANGO_V32F20X_SPI_ENABLED
    select SPI
    help
      Enable support for Vango V32F20X SPI.

config CAN_V32F20X
    bool "V32F20X CAN Driver"
    default y
    depends on DT_HAS_VANGO_V32F20X_CAN_ENABLED
    select CAN
    help
      Enable support for Vango V32F20X CAN.

