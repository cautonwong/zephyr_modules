#include <arm/armv8-m.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pinctrl/vango-v32f20x-pinctrl.h>
#include <mem.h>

/ {
    cpus {
        #address-cells = <1>;
        #size-cells = <0>;

        cpu0: cpu@0 {
            device_type = "cpu";
            compatible = "arm,cortex-m0";
            reg = <0>;
        };

        cpu1: cpu@1 {
            device_type = "cpu";
            compatible = "arm,cortex-m33";
            reg = <1>;
        };
    };

    sram0: memory@20000000 {
        compatible = "mmio-sram";
        reg = <0x20000000 DT_SIZE_K(1088)>;
    };

    ipc_shm_0: memory@20110000 {
        compatible = "zephyr,ipc_shm";
        reg = <0x20110000 DT_SIZE_K(8)>;
    };

    ipc_shm_1: memory@20112000 {
        compatible = "zephyr,ipc_shm";
        reg = <0x20112000 DT_SIZE_K(8)>;
    };

    flash0: flash@8000000 {
        compatible = "vango,v32f20x-flash-controller";
        reg = <0x08000000 DT_SIZE_K(2304)>;
    };

    soc: soc {
        syscfg: syscfg@40200000 {
            compatible = "vango,v32f20x-syscfg", "syscon";
            reg = <0x40200000 0x1000>;

            reset: reset-controller {
                compatible = "vango,v32f20x-reset";
                #reset-cells = <1>;
            };

            clock: clock-controller {
                compatible = "vango,v32f20x-clock";
                #clock-cells = <1>;
            };

            mbox: mbox {
                compatible = "vango,v32f20x-mbox";
                interrupts = <0 1>, <1 1>;
                #mbox-cells = <1>;
                status = "okay";
            };
        };

        pinctrl: pinctrl@40100000 {
            compatible = "vango,v32f20x-pinctrl";
            reg = <0x40100000 0x1000>;
        };

        gpioa: gpio@40100000 {
            compatible = "vango,v32f20x-gpio";
            reg = <0x40100000 0x400>;
            interrupts = <29 1>;
            gpio-controller;
            #gpio-cells = <2>;
            vango,port = <0>;
            status = "disabled";
        };

        gpiob: gpio@40100400 {
            compatible = "vango,v32f20x-gpio";
            reg = <0x40100400 0x400>;
            interrupts = <29 1>;
            gpio-controller;
            #gpio-cells = <2>;
            vango,port = <1>;
            status = "disabled";
        };

        uart0: uart@40000000 {
            compatible = "vango,v32f20x-uart";
            reg = <0x40000000 0x400>;
            interrupts = <0 1>;
            clocks = <&clock 0>;
            resets = <&reset 0>;
            status = "disabled";
        };

        uart1: uart@40000400 {
            compatible = "vango,v32f20x-uart";
            reg = <0x40000400 0x400>;
            interrupts = <1 1>;
            clocks = <&clock 1>;
            resets = <&reset 1>;
            status = "disabled";
        };

        uart14: uart@40003800 {
            compatible = "vango,v32f20x-uart";
            reg = <0x40003800 0x400>;
            interrupts = <14 1>;
            clocks = <&clock 14>;
            resets = <&reset 14>;
            status = "disabled";
        };

        adc0: adc@40010000 {
            compatible = "vango,v32f20x-adc";
            reg = <0x40010000 0x400>;
            interrupts = <15 1>;
            clocks = <&clock 15>;
            resets = <&reset 15>;
            status = "disabled";
            #io-channel-cells = <1>;
        };

        dma0: dma@40020000 {
            compatible = "vango,v32f20x-dma";
            reg = <0x40020000 0x400>;
            interrupts = <20 1>;
            clocks = <&clock 20>;
            resets = <&reset 20>;
            #dma-cells = <2>;
            status = "disabled";
        };
    };
};

&nvic {
    arm,num-irq-priority-bits = <2>;
};
