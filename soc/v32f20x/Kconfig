# 2. Basic IO (Legacy support for simple toggles)
config V32F20X_GPIO
    bool "Vango V32F20X GPIO Driver"
    default y if GPIO
    depends on SOC_SERIES_V32F20X
    select VANGO_V32F20X_HAL_GPIO
    help
      Enable the Vango V32F20X GPIO driver.

config V32F20X_UART
    select SERIAL_SUPPORT_ASYNC
    bool "Vango V32F20X UART Driver"
    default y if SERIAL
    depends on SOC_SERIES_V32F20X
    select SERIAL_HAS_DRIVER
    select VANGO_V32F20X_HAL_UART
    help
      Enable the Vango V32F20X UART driver.

config ADC_V32F20X
    bool "Vango V32F20X ADC Driver"
    default y if ADC
    depends on SOC_SERIES_V32F20X
    select VANGO_V32F20X_HAL_ADC
    help
      Enable the Vango V32F20X ADC driver.
