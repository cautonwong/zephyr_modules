if SOC_SERIES_V32F20X

config SOC_SERIES
	default "v32f20x"

config SOC
	default "v32f20x"

config SYS_CLOCK_HW_CYCLES_PER_SEC
	default 160000000

config NUM_IRQS
	default 128

if SOC_V32F20X_CPU1 # M33
config ARM_MPU
	default y
config FPU
	default y
endif

endif # SOC_SERIES_V32F20X
